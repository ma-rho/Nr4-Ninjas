{
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "source": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ]
  },
  "appHosting": {
    "region": "us-central1",
    "secretEnvironmentVariables": [
      {
        "key": "NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET",
        "secret": "NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET"
      }
    ]
  }
}
